<style>
  :root {
    --gold: #FFD700;
    --gold-light: #FFF0A0;
    --gold-dark: #B8860B;
    --bg: #080A10;
    --card: #0E1120;
    --card-border: rgba(255,215,0,0.18);
    --text: #F0EFE8;
    --muted: #8A8F9E;
    --green: #00E676;
    --wa: #25D366;
    --wa-dark: #128C7E;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Sora', sans-serif;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
    overflow-x: hidden;
  }

  /* Animated background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% -10%, rgba(255,215,0,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 90% 90%, rgba(0,230,118,0.05) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  .card {
    position: relative;
    z-index: 1;
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: 28px;
    padding: 40px 32px 36px;
    max-width: 420px;
    width: 100%;
    box-shadow:
      0 0 0 1px rgba(255,215,0,0.06),
      0 32px 80px rgba(0,0,0,0.6),
      inset 0 1px 0 rgba(255,215,0,0.12);
    animation: fadeUp 0.7s cubic-bezier(.22,1,.36,1) both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Ticker shimmer at top */
  .ticker-strip {
    display: flex;
    gap: 10px;
    margin-bottom: 28px;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
  }
  .ticker-item {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.5px;
    padding: 4px 10px;
    border-radius: 20px;
    animation: tickerSlide 12s linear infinite;
  }
  .up   { background: rgba(0,230,118,0.12); color: var(--green); }
  .down { background: rgba(255,80,80,0.12); color: #FF5050; }

  @keyframes tickerSlide {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-120px); }
  }

  /* Logo area */
  .logo-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 6px;
  }

  .logo-icon {
    width: 52px;
    height: 52px;
    background: linear-gradient(135deg, var(--gold) 0%, #FFA500 100%);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    box-shadow: 0 4px 20px rgba(255,215,0,0.35);
    flex-shrink: 0;
  }

  .brand-name {
    font-family: 'Clash Display', sans-serif;
    font-size: 34px;
    font-weight: 700;
    background: linear-gradient(120deg, var(--gold-light) 0%, var(--gold) 50%, #FFA500 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.5px;
  }

  .tagline {
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.3px;
    margin-bottom: 4px;
    margin-top: 2px;
  }

  .exp-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(255,215,0,0.1);
    border: 1px solid rgba(255,215,0,0.2);
    border-radius: 20px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 500;
    color: var(--gold);
    margin: 14px 0 20px;
  }
  .exp-badge span { font-size: 15px; }

  /* Divider */
  .divider {
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,215,0,0.2), transparent);
    margin-bottom: 20px;
  }

  /* Specializations */
  .section-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(255,215,0,0.15);
  }

  .feature-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 22px;
  }

  .feature-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: #C8CAD4;
    line-height: 1.5;
    animation: fadeUp 0.6s cubic-bezier(.22,1,.36,1) both;
  }

  .feature-list li:nth-child(1) { animation-delay: 0.1s; }
  .feature-list li:nth-child(2) { animation-delay: 0.18s; }
  .feature-list li:nth-child(3) { animation-delay: 0.26s; }
  .feature-list li:nth-child(4) { animation-delay: 0.34s; }
  .feature-list li:nth-child(5) { animation-delay: 0.42s; }
  .feature-list li:nth-child(6) { animation-delay: 0.50s; }

  .feat-dot {
    width: 20px;
    height: 20px;
    border-radius: 6px;
    background: rgba(255,215,0,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
    font-size: 11px;
  }

  /* Capital badge */
  .capital-box {
    background: linear-gradient(135deg, rgba(0,230,118,0.06), rgba(0,230,118,0.02));
    border: 1px solid rgba(0,230,118,0.2);
    border-radius: 14px;
    padding: 13px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .capital-icon {
    font-size: 22px;
    flex-shrink: 0;
  }

  .capital-text {
    font-size: 12.5px;
    color: var(--muted);
    line-height: 1.4;
  }

  .capital-text strong {
    display: block;
    font-size: 14px;
    color: var(--green);
    font-weight: 600;
    margin-bottom: 2px;
  }

  /* CTA */
  .cta-wrapper {
    position: relative;
  }

  /* Liquid blob behind button */
  .liquid-blob {
    position: absolute;
    inset: -12px;
    border-radius: 40px;
    background: linear-gradient(135deg, var(--wa), var(--wa-dark), #075E54);
    filter: blur(18px);
    opacity: 0.45;
    animation: liquidPulse 3s ease-in-out infinite;
    z-index: 0;
  }

  @keyframes liquidPulse {
    0%, 100% {
      transform: scale(1) rotate(0deg);
      border-radius: 40px;
      opacity: 0.4;
    }
    25% {
      transform: scale(1.04) rotate(1.5deg);
      border-radius: 50% 40% 55% 35% / 40% 55% 35% 50%;
      opacity: 0.55;
    }
    50% {
      transform: scale(1.06) rotate(-1deg);
      border-radius: 35% 55% 40% 50% / 55% 35% 50% 40%;
      opacity: 0.5;
    }
    75% {
      transform: scale(1.02) rotate(2deg);
      border-radius: 50% 38% 52% 38% / 38% 52% 38% 52%;
      opacity: 0.55;
    }
  }

  .wa-btn {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 16px 24px;
    background: linear-gradient(135deg, #2ECC71 0%, var(--wa) 50%, var(--wa-dark) 100%);
    border: none;
    border-radius: 16px;
    color: #fff;
    font-family: 'Sora', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.3px;
    cursor: pointer;
    text-decoration: none;
    box-shadow:
      0 4px 24px rgba(37,211,102,0.3),
      inset 0 1px 0 rgba(255,255,255,0.25);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    overflow: hidden;
  }

  /* Shine sweep */
  .wa-btn::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
    animation: shine 3.5s ease-in-out infinite;
  }

  @keyframes shine {
    0%   { left: -100%; }
    40%, 100% { left: 160%; }
  }

  .wa-btn:hover {
    transform: translateY(-2px) scale(1.015);
    box-shadow:
      0 8px 32px rgba(37,211,102,0.45),
      inset 0 1px 0 rgba(255,255,255,0.3);
  }

  .wa-btn:active {
    transform: translateY(0) scale(0.98);
  }

  /* WhatsApp SVG icon */
  .wa-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  /* Footer note */
  .footer-note {
    text-align: center;
    font-size: 11px;
    color: var(--muted);
    margin-top: 16px;
    opacity: 0.6;
  }

  /* Floating particles */
  .particles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    width: 2px;
    height: 2px;
    border-radius: 50%;
    background: rgba(255,215,0,0.4);
    animation: floatUp linear infinite;
  }

  @keyframes floatUp {
    from { transform: translateY(100vh) scale(0); opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 0.5; }
    to   { transform: translateY(-10vh) scale(1.5); opacity: 0; }
  }
</style>
</head>
